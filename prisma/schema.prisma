generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sport {
  MLB
  NBA
  NHL
  NCAAM
  NFL
  NCAAF
}

model MlbTeamStatSnapshot {
  id           String   @id @default(cuid())
  businessDate DateTime
  sourceSeason Int
  fetchedAt    DateTime
  payload      Json
  createdAt    DateTime @default(now())

  @@unique([businessDate, sourceSeason])
  @@map("TeamStatSnapshot")
}

model MlbSlateGame {
  id           String   @id @default(cuid())
  businessDate DateTime
  lookupKey    String
  awayTeam     String
  homeTeam     String
  gameTime     String?
  gameDateIso  DateTime?
  status       String   @default("loaded")
  context      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([businessDate, lookupKey])
  @@map("SlateGame")
}

model MlbMarketOddsSnapshot {
  id           String   @id @default(cuid())
  businessDate DateTime
  lookupKey    String
  source       String
  odds         Json
  createdAt    DateTime @default(now())

  @@unique([businessDate, lookupKey, source])
  @@map("MarketOddsSnapshot")
}

model MlbOddsOverride {
  id           String   @id @default(cuid())
  sport        Sport    @default(MLB)
  businessDate DateTime
  lookupKey    String
  awayTeam     String
  homeTeam     String
  source       String
  status       String   @default("staged")
  odds         Json
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([sport, businessDate, lookupKey, source])
  @@index([sport, businessDate, status])
  @@map("OddsOverride")
}

model MlbSharpSignalRaw {
  id           String   @id @default(cuid())
  businessDate DateTime
  lookupKey    String
  provider     String
  payload      Json
  fetchedAt    DateTime @default(now())

  @@unique([businessDate, lookupKey, provider])
  @@map("SharpSignalRaw")
}

model MlbSharpSignalNormalized {
  id                     String   @id @default(cuid())
  businessDate           DateTime
  lookupKey              String
  provider               String
  source                 String
  steamLean              String
  reverseLean            String
  openingHomeMoneyline   Int?
  openingAwayMoneyline   Int?
  openingTotal           Float?
  moneylineHomeBetsPct   Float?
  moneylineHomeMoneyPct  Float?
  totalOverBetsPct       Float?
  totalOverMoneyPct      Float?
  snapshot               Json
  lastUpdated            DateTime
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([businessDate, lookupKey, provider])
  @@map("SharpSignalNormalized")
}

model PredictionRun {
  id            String       @id @default(cuid())
  sport         Sport        @default(MLB)
  businessDate  DateTime
  modelVersion  String
  reviewStatus  String       @default("pending_review")
  status        String       @default("completed")
  exportPath    String?
  resultsPath   String?
  summary       Json
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  mlbPredictions MlbPrediction[]
  predictionFiles PredictionFile[]
  resultFiles     ResultFile[]

  @@index([sport, businessDate, createdAt(sort: Desc)])
}

model MlbPrediction {
  id              String        @id @default(cuid())
  predictionRunId String
  businessDate    DateTime
  lookupKey       String
  awayTeam        String
  homeTeam        String
  payload         Json
  createdAt       DateTime      @default(now())
  predictionRun   PredictionRun @relation(fields: [predictionRunId], references: [id], onDelete: Cascade)

  @@unique([predictionRunId, lookupKey])
  @@index([businessDate, lookupKey])
  @@map("Prediction")
}

model MlbGameResult {
  id           String   @id @default(cuid())
  businessDate DateTime
  lookupKey    String
  awayTeam     String
  homeTeam     String
  awayScore    Int
  homeScore    Int
  payload      Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([businessDate, lookupKey])
  @@map("GameResult")
}

model EvaluationSummary {
  id           String   @id @default(cuid())
  sport        Sport    @default(MLB)
  fromDate     DateTime
  toDate       DateTime
  modelVersion String?
  thresholds   Json
  summary      Json
  createdAt    DateTime @default(now())
}

model ModelVersion {
  id          String   @id @default(cuid())
  sport       Sport    @default(MLB)
  version     String
  description String?
  parameters  Json
  status      String   @default("active")
  createdAt   DateTime @default(now())

  @@unique([sport, version])
}

model CalibrationRun {
  id           String   @id @default(cuid())
  sport        Sport    @default(MLB)
  modelVersion String?
  status       String   @default("planned")
  output       Json
  createdAt    DateTime @default(now())
}

model PredictionFile {
  id              String        @id @default(cuid())
  sport           Sport
  businessDate    DateTime
  source          String
  path            String
  fileRole        String        @default("export")
  metadata        Json?
  predictionRunId String?
  createdAt       DateTime      @default(now())
  predictionRun   PredictionRun? @relation(fields: [predictionRunId], references: [id], onDelete: SetNull)

  @@index([sport, businessDate, createdAt(sort: Desc)])
}

model ResultFile {
  id              String        @id @default(cuid())
  sport           Sport
  businessDate    DateTime
  source          String
  path            String
  fileRole        String        @default("export")
  metadata        Json?
  predictionRunId String?
  createdAt       DateTime      @default(now())
  predictionRun   PredictionRun? @relation(fields: [predictionRunId], references: [id], onDelete: SetNull)

  @@index([sport, businessDate, createdAt(sort: Desc)])
}
